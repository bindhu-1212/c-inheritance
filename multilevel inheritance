#include<iostream>
#include<string>
using namespace std;
class Person
{
    protected: string name;
    int id;
    int age;
    public: Person(string pername, int perid, int perage): name(pername),
    id(perid),
    age(perage) {}
    void show()
    {
        cout << " Name = " << name;
        cout << " \n ID = " << id;
        cout << " \n Age = " << age;
    }

};
class Student: public Person
{
    protected: string dept;
    double gpa;
    public: Student(string studname, int studid, int studage, string studdept, double studgpa): Person(studname, studid, studage),
    dept(studdept),
    gpa(studgpa) {}

    void show1() 
    {
        show();
        cout << "\n Dept = " << dept;
        cout << "\n GPA = " << gpa;
    }

};
class GraduateStudent: public Student
{
    protected: string topic;
    public: GraduateStudent(string gradname, int gradid, int gradage, string graddept, double gradgpa, string gradtopic): Student(gradname, gradid, gradage, graddept, gradgpa),
    topic(gradtopic) {}

    void show2()
    {
        show1();
        cout << " Topic = " << topic;
    }
};
int main()
{
    GraduateStudent g1("Bindhu", 1, 21, "CSE", 8.56, "OOPS");
    g1.show2();

}
